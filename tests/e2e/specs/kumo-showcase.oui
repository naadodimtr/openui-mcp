root = Stack([header, typographySection, badgeSection, buttonSection, cardSection, calloutSection, codeSection, layoutSection, contentSection, dataSection, formSection, interactiveSection], "column", "lg")

header = Stack([Text("Kumo Full Variant Showcase", "lg", "bold"), Text("40 components with all variants", "sm", "normal", "subtle")], "column", "xs")

typographySection = Card([Text("Typography", "base", "semibold"), Separator(), Stack([Text("Size xs", "xs"), Text("Size sm", "sm"), Text("Size base", "base"), Text("Size lg", "lg")], "row", "sm"), Separator(), Stack([Text("Normal", "base", "normal"), Text("Medium", "base", "medium"), Text("Semibold", "base", "semibold"), Text("Bold", "base", "bold")], "row", "sm"), Separator(), Stack([Text("Default", "sm", "normal", "default"), Text("Subtle", "sm", "normal", "subtle"), Text("Muted", "sm", "normal", "muted"), Text("Accent", "sm", "normal", "accent"), Text("Success", "sm", "normal", "success"), Text("Warning", "sm", "normal", "warning"), Text("Danger", "sm", "normal", "danger")], "row", "sm")])

badgeSection = Card([Text("Badges (8 variants)", "base", "semibold"), Separator(), Stack([Badge("Neutral"), Badge("Info", "info"), Badge("Success", "success"), Badge("Warning", "warning"), Badge("Danger", "danger"), Badge("Error", "error"), Badge("Primary", "primary"), Badge("Secondary", "secondary")], "row", "xs")])

buttonSection = Card([Text("Buttons (5 variants x 4 sizes)", "base", "semibold"), Separator(), Stack([Button("Primary", "primary"), Button("Secondary", "secondary"), Button("Ghost", "ghost"), Button("Destructive", "destructive"), Button("Outline", "outline")], "row", "xs"), Separator(), Stack([Button("XS", "primary", "xs"), Button("SM", "primary", "sm"), Button("Base", "primary", "base"), Button("LG", "primary", "lg")], "row", "xs"), Separator(), Stack([LinkButton("Link Primary", "/a"), LinkButton("Link Secondary", "/b", "secondary"), LinkButton("Link Ghost", "/c", "ghost")], "row", "xs")])

cardSection = Stack([Card([Text("Elevated Card (p-6)")], "elevated"), Card([Text("Outlined Card (p-5)")], "outlined"), Card([Text("Ghost Card (p-4)")], "ghost")], "row", "md")

calloutSection = Card([Text("Callouts (4 variants)", "base", "semibold"), Separator(), Callout("info", "Information", "This is informational."), Callout("success", "Success", "Operation completed."), Callout("warning", "Warning", "Approaching limit."), Callout("danger", "Error", "Service degraded.")])

codeSection = Card([Text("Code (4 languages) & Clipboard (3 sizes)", "base", "semibold"), Separator(), Code("typescript", "const x: number = 42;"), Code("bash", "curl -fsSL https://example.com"), Code("css", ".card { padding: 1rem; }"), Code("jsonc", "{ \"key\": \"value\" }"), Separator(), ClipboardText("sm clipboard", "sm"), ClipboardText("base clipboard", "base"), ClipboardText("lg clipboard", "lg")])

layoutSection = Card([Text("Layout Components", "base", "semibold"), Separator(), Stack([Text("Grid:"), Grid([LayerCard([Text("Cell A")]), LayerCard([Text("Cell B")]), LayerCard([Text("Cell C")]), LayerCard([Text("Cell D")])])], "column", "xs"), Separator(), Stack([Text("Separator vertical:"), Stack([Text("Left"), Separator("vertical"), Text("Right")], "row", "sm", "center")], "column", "xs"), Separator(), Stack([Text("Tabs:"), Tabs([TabItem("t1", "Overview", [Text("Overview content")]), TabItem("t2", "Settings", [Text("Settings content")])])], "column", "xs"), Separator(), Stack([Text("Collapsible:"), Collapsible("Show Advanced", [Text("Hidden content revealed")])], "column", "xs")])

contentSection = Card([Text("Content Components", "base", "semibold"), Separator(), Stack([Text("Empty sizes:"), Empty("Small", "No items", "sm"), Empty("Base", "No items", "base"), Empty("Large", "No items", "lg")], "column", "xs"), Separator(), Stack([Text("Labels:"), Label("Required"), Label("Optional", true)], "column", "xs"), Separator(), Stack([Text("Links:"), Stack([Link("Inline", "https://a.com", "inline"), Link("Current", "https://b.com", "current"), Link("Plain", "https://c.com", "plain")], "row", "sm")], "column", "xs"), Separator(), Stack([Text("Loaders:"), Stack([Loader("sm"), Loader("base"), Loader("lg")], "row", "sm")], "column", "xs"), Separator(), Stack([Text("Breadcrumbs:"), Breadcrumbs([BreadcrumbItem("Home", "/"), BreadcrumbItem("Section", "/s"), BreadcrumbItem("Page")])], "column", "xs"), Separator(), Stack([Text("Tooltip:"), Tooltip("Helpful tip", [Badge("Hover me", "info")])], "column", "xs"), Separator(), Stack([Text("Skeleton:"), Skeleton(3)], "column", "xs")])

dataSection = Card([Text("Data Components", "base", "semibold"), Separator(), Table([TableColumn("Service", ["Workers", "Pages", "R2"]), TableColumn("Status", ["Active", "Active", "Beta"]), TableColumn("Requests", ["1.2M", "890K", "340K"])]), Separator(), Meter(85, 100, "CPU"), Meter(42, 100, "Memory"), Meter(10, 100, "Disk"), Separator(), Pagination(8, 3)])

formSection = Card([Text("Form Controls", "base", "semibold"), Separator(), Stack([Field("Full Name", "Required field", [Input("name", "John Doe", "text")]), Field("Email", "Work email preferred", [Input("email", "you@work.com", "email")]), Input("pass", "Password", "password"), Input("age", "Age", "number"), Input("site", "https://...", "url")], "column", "xs"), Separator(), Textarea("bio", "Tell us about yourself...", 3), Separator(), SensitiveInput("apiKey", "Enter API key", "API Key"), Separator(), Select("region", [SelectItem("us", "United States"), SelectItem("eu", "Europe"), SelectItem("ap", "Asia Pacific")], "Choose region..."), Separator(), RadioGroup("plan", [RadioItem("free", "Free"), RadioItem("pro", "Pro"), RadioItem("enterprise", "Enterprise")], "pro"), Separator(), Stack([Switch("dark", "Dark mode"), Switch("notify", "Notifications"), Checkbox("tos", "Accept terms"), Checkbox("news", "Subscribe")], "column", "xs"), Separator(), DatePicker("startDate", "Start Date")])

interactiveSection = Card([Text("Interactive Patterns", "base", "semibold"), Separator(), Dialog("Delete Worker", "This action cannot be undone.", [Stack([Button("Cancel", "secondary"), Button("Delete", "destructive")], "row", "xs")]), Separator(), DropdownMenu("Actions", [MenuItem("Edit"), MenuItem("Duplicate"), MenuItem("", true), MenuItem("Delete")])])
