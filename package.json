{
  "name": "@naadodimtr/openui-mcp",
  "version": "1.1.3",
  "description": "MCP server for OpenUI - create structured web UI through AI chat",
  "type": "module",
  "scripts": {
    "dev": "bun src/server.ts",
    "test": "bun test",
    "test:kumo": "bun test ./adapters/kumo/tests/renderer.test.ts",
    "test:e2e": "bunx playwright test",
    "test:all": "bun test && bun test ./adapters/kumo/tests/renderer.test.ts && bunx playwright test",
    "embed": "bun scripts/embed-assets.ts",
    "prebuild": "cd previewer && bun run build && cd .. && bun run embed",
    "build": "bun build --compile src/server.ts --outfile dist/openui-mcp",
    "build:linux": "bun build --compile src/server.ts --target=bun-linux-x64 --outfile dist/openui-mcp-linux",
    "build:mac": "bun build --compile src/server.ts --target=bun-darwin-arm64 --outfile dist/openui-mcp-darwin",
    "build:win": "bun build --compile src/server.ts --target=bun-windows-x64 --outfile dist/openui-mcp.exe"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openuidev/lang-core": "^0.2.5",
    "@openuidev/react-lang": "^0.2.6",
    "@openuidev/react-ui": "^0.11.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/kumo": "^2.5.2",
    "@phosphor-icons/react": "^2.1.10",
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "echarts": "^6.1.0"
  },
  "keywords": ["mcp", "openui", "generative-ui", "ai"],
  "license": "MIT"
}
