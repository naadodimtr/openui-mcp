{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenUI MCP Adapter Spec",
  "type": "object",
  "required": ["id", "name", "version", "components"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "upstream": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "styles": {
      "type": "object",
      "properties": {
        "entry": { "type": "string" },
        "framework": {
          "type": "string",
          "enum": ["tailwind-v4", "tailwind-v3", "css-modules", "plain-css"]
        }
      },
      "required": ["entry"]
    },
    "root": {
      "type": "string"
    },
    "componentGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "components"],
        "properties": {
          "name": { "type": "string" },
          "components": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "import", "description", "props"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "import": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "props": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "position"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean", "default": false },
                "position": { "type": "integer", "minimum": 0 },
                "default": {},
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
